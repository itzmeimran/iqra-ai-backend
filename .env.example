# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/genai-chat
MONGODB_DB_NAME=genai-chat

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-super-secret-key-256bit
JWT_REFRESH_SECRET=change-me-refresh-super-secret-key-256bit
JWT_ACCESS_EXPIRES_IN=15          # minutes
JWT_REFRESH_EXPIRES_IN=10080      # minutes (7 days)

# ── Google SSO ─────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── LLM Runtime ────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama                           # ollama | lmstudio | vllm | cloud
LLM_BASE_URL=http://localhost:11434           # Ollama default
DEFAULT_MODEL=llama3                          # llama3 | mistral | phi3 | etc.

# ── LangSmith (optional) ───────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=genai-chat-backend
LANGCHAIN_API_KEY=                            # Leave empty if self-hosted

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
